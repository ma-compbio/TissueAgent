p_means = base / "tables" / "celltype_means.tsv"
p_cmap = base / "tables" / "colormap_resolved.tsv"
p_ref = base / "uploads" / "reference_lohoff-2e.png"

# Validate paths are inside DATA_DIR and exist
for p in [p_tstats, p_means, p_cmap, p_ref]:
    assert str(p.resolve()).startswith(str(base)), f"Path outside DATA_DIR: {p}"
