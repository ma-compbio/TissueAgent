    "gene_var_index_name": context["gene_var_index_name"],
    "matrix_format": context["matrix_format"],
    "anndata_uns_keys": context["anndata_uns_keys"],
}

with open(out_config_path, "w", encoding="utf-8") as f:
    json.dump(config_payload, f, indent=2, ensure_ascii=False)

print("Wrote config JSON:", str(out_config_path.resolve()))
print(json.dumps(config_payload, indent=2)[:500] + ("..." if len(json.dumps(config_payload, indent=2))>500 else ""))</execute>

