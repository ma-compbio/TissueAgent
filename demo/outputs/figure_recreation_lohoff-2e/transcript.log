# Helper: file hash
def sha256_of_file(p: Path, block_size: int = 1 << 20) -> str:
    h = hashlib.sha256()
    with open(p, "rb") as f:
        while True:
            b = f.read(block_size)
            if not b:
                break
            h.update(b)
    return h.hexdigest()

# Input paths
p_tstats = DATA_DIR / "tables" / "tstats_long.tsv"
p_means = DATA_DIR / "tables" / "celltype_means.tsv"
p_cmap = DATA_DIR / "tables" / "colormap_resolved.tsv"
