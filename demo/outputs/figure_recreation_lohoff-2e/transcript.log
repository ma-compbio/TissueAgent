        "width": plot_style["violin_width"],
        "linewidth": plot_style["violin_linewidth"],
        "cut": plot_style["violin_cut"],
        "inner": plot_style["inner"],
    },
    "axes_style": {
        "spine_linewidth": plot_style["spine_linewidth"],
        "tick_width": plot_style["tick_width"],
        "grid": plot_style["grid"],
        "ylabel": "t-statistic",
    },
}

with open(cfg_path, "w") as f:
