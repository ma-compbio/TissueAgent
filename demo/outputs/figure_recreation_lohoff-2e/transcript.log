import numpy as np
import pandas as pd
from pathlib import Path
from scipy import sparse
from sklearn.neighbors import NearestNeighbors

# 1) Parameters and I/O setup
out_dir = DATA_DIR / "tables"
out_dir.mkdir(parents=True, exist_ok=True)
long_path = out_dir / "tstats_long.tsv"
pivot_path = out_dir / "tstats_pivot.tsv"
means_path = out_dir / "celltype_means.tsv"

ct_key = "celltype_mapped_refined"

# Pull gene identifiers
# Prefer cfg['gene_var_index_name'] if it exists and matches a column in adata.var.
gene_index_name = cfg.get("gene_var_index_name", None)
if gene_index_name and gene_index_name in adata.var.columns:
    genes = adata.var[gene_index_name].astype(str).values
else:
    genes = adata.var_names.astype(str).values
print("Gene identifier source:", "var[" + gene_index_name + "]" if (gene_index_name and gene_index_name in adata.var.columns) else "var_names")
print("n_genes:", len(genes))

# 2) Build spatial kNN graph from obsm['spatial']
assert "spatial" in adata.obsm, "Missing obsm['spatial'] with spatial coordinates."
coords = np.asarray(adata.obsm["spatial"])
assert coords.shape[0] == adata.n_obs and coords.shape[1] >= 2, f"Unexpected spatial shape: {coords.shape}"

K = 10  # assumption per typical spatial neighbor sizes
nbrs = NearestNeighbors(n_neighbors=K+1, algorithm="auto", metric="euclidean")
nbrs.fit(coords)
dists, idxs = nbrs.kneighbors(coords, return_distance=True)

# Remove self neighbor (distance 0)
dists = dists[:, 1:]
idxs = idxs[:, 1:]

# Handle any zero distances (coincident cells) by setting weight 0 (exclude)
with np.errstate(divide='ignore', invalid='ignore'):
    weights = 1.0 / dists
    weights[~np.isfinite(weights)] = 0.0  # inf or nan -> 0

n_cells = adata.n_obs
rows = np.repeat(np.arange(n_cells), K)
cols = idxs.reshape(-1)
data = weights.reshape(-1)
W = sparse.csr_matrix((data, (rows, cols)), shape=(n_cells, n_cells))
print("Sparse neighbor weight matrix W:", W.shape, "nnz:", W.nnz)

# 3) Prepare expression matrix
X = adata.X
if sparse.issparse(X):
    X = X.tocsr()
    X = X.astype(np.float32)
    X_dense = X.toarray()
else:
    X_dense = np.asarray(X, dtype=np.float32, order="C")
print("Expression matrix X_dense shape:", X_dense.shape, "dtype:", X_dense.dtype)

# 4) Compute neighbor-weighted expression X_star = W @ X
# Use float32 to manage memory
X_star = (W @ X_dense).astype(np.float32)
print("Computed X_star shape:", X_star.shape, "dtype:", X_star.dtype)

# 5) Prepare cell-type groups and ensure order
obs_ct = adata.obs[ct_key].astype(str).values
# Preserve order as seen earlier
cell_types_order = list(pd.unique(adata.obs[ct_key].astype(str)))
print("Cell types order (len):", len(cell_types_order))

# 6) For each cell type and each gene compute t-statistic via correlation-based formula
records = []
min_cells = 3  # minimal sample size to compute t-statistic (intercept + slope requires n>=3)

for ct in cell_types_order:
    idx = np.where(obs_ct == ct)[0]
    n = idx.size
    if n < min_cells:
        # Skip producing any rows for this cell type due to insufficient cells
        print(f"Skipping cell type '{ct}' due to insufficient cells (n={n} < {min_cells}).")
        continue

    Y = X_dense[idx, :]   # n x g
    P = X_star[idx, :]    # n x g

    # Center Y and P
    Y_mean = Y.mean(axis=0, dtype=np.float64)  # higher precision for mean
    P_mean = P.mean(axis=0, dtype=np.float64)

    Yc = (Y - Y_mean).astype(np.float32)
    Pc = (P - P_mean).astype(np.float32)

    # Compute per-gene sums
    num = np.sum(Yc * Pc, axis=0, dtype=np.float64)  # numerator: sum((y - ybar)*(p - pbar))
    yss = np.sum(Yc * Yc, axis=0, dtype=np.float64)  # sum squares y
    pss = np.sum(Pc * Pc, axis=0, dtype=np.float64)  # sum squares p

    denom = np.sqrt(yss * pss, dtype=np.float64)
    with np.errstate(divide='ignore', invalid='ignore'):
        r = num / denom
        # Clip r into (-1, 1) to avoid infs from numerical precision; still keep NaN if denom == 0
        r = np.clip(r, -0.999999, 0.999999, where=np.isfinite(r))
        # t-statistic for slope in simple linear regression with intercept
        t = r * np.sqrt((n - 2) / (1.0 - r * r))

    # Valid where denom > 0 (non-constant y and p)
    valid = denom > 0
    # Build records only for valid gene×cell_type as required
    valid_idx = np.where(valid)[0]
    if valid_idx.size == 0:
        # No valid genes for this cell type (unlikely)
        print(f"No valid gene t-stats for cell type '{ct}'.")
        continue

    # Append records
    for gi in valid_idx:
        records.append((genes[gi], ct, float(t[gi])))

# 7) Assemble long table
long_df = pd.DataFrame.from_records(records, columns=["gene", "cell_type", "t_statistic"])
print("Long table size:", long_df.shape)
# Basic sanity: number of unique genes, cell types present
print("Unique genes in long:", long_df['gene'].nunique(), "Unique cell types in long:", long_df['cell_type'].nunique())

# 8) Build pivot with full column order, same set of gene×cell_type as long_df; missing values allowed
pivot_df = long_df.pivot_table(index="gene", columns="cell_type", values="t_statistic", aggfunc="first")
# Reindex columns to preserve original cell type order
pivot_df = pivot_df.reindex(columns=cell_types_order)

# 9) Compute mean t-statistic per cell type
means_df = long_df.groupby("cell_type", as_index=False)["t_statistic"].mean().rename(columns={"t_statistic": "mean_tstatistic"})
# Preserve order in means_df
means_df["cell_type"] = pd.Categorical(means_df["cell_type"], categories=cell_types_order, ordered=True)
means_df = means_df.sort_values("cell_type").reset_index(drop=True)

# 10) Save artifacts
long_df.to_csv(long_path, sep="\t", index=False)
pivot_df.to_csv(pivot_path, sep="\t")
means_df.to_csv(means_path, sep="\t", index=False)

print("Saved:")
print(" -", long_path)
print(" -", pivot_path)
print(" -", means_path)

# 11) Print small checks
print("\nPreview long_df:")
print(long_df.head(10))
print("\nPivot shape:", pivot_df.shape)
print("Means preview:")
print(means_df.head(10))
</execute>

