<execute>
from pathlib import Path
import re

# Access DATA_DIR from the REPL
base = DATA_DIR
md_path = base / "uploads" / "instructions_lohoff-2e.md"

assert str(md_path.resolve()).startswith(str(base.resolve())), "Path escapes DATA_DIR"
print("Exists:", md_path.exists(), "Path:", md_path)

text = md_path.read_text(encoding="utf-8")

print("--- Document head (first 600 chars) ---")
print(text[:600] + ("..." if len(text) > 600 else ""))

# Find key sections/keywords and print surrounding context
keywords = [
    r"t[- ]?stat", r"t statistic", r"filter", r"minimum", r"min cells", r"cell[- ]?type",
    r"variance", r"constant", r"zero variance", r"spatial", r"coordinates", r"X_spatial",
    r"obsm", r"regression", r"model", r"formula", r"edge case", r"threshold", r"standardize",
    r"normalize", r"log1p", r"smooth", r"neighbors", r"random", r"seed"
]

def find_context(txt, pattern, width=280):
    out = []
    for m in re.finditer(pattern, txt, flags=re.IGNORECASE):
        start = max(0, m.start() - width)
        end = min(len(txt), m.end() + width)
        snippet = txt[start:end].replace("\n", " ").strip()
        out.append(snippet)
        if len(out) >= 5:
            break
    return out

print("\n--- Matched excerpts ---")
found_any = False
for kw in keywords:
    ctxs = find_context(text, kw)
    if ctxs:
        found_any = True
        print(f"\n[#] Keyword: {kw}")
        for i, c in enumerate(ctxs, 1):
            print(f"  ({i}) ...{c}...")
if not found_any:
    print("No keyword matches found; will rely on full document content.")

# Try to heuristically extract explicit numeric thresholds and the t-stat definition line(s)
num_patterns = [
    r"min(?:imum)?\s+cells?\s*(?:per\s+(?:group|cell[- ]?type))?\s*[:=]\s*(\d+)",
    r"min(?:imum)?\s+genes?\s*[:=]\s*(\d+)",
    r"min(?:imum)?\s+variance\s*[:=]\s*([0-9]*\.?[0-9]+)",
    r"min(?:imum)?\s+counts\s*[:=]\s*(\d+)"
]
print("\n--- Heuristic numeric threshold extraction ---")
for pat in num_patterns:
