# Step 5: Validate artifacts and perform basic checks.
from pathlib import Path
import json
import pandas as pd

# Relative artifact paths
rel_config = Path("configs/lohoff2e_config.json")
rel_cmap = Path("tables/colormap_resolved.tsv")
rel_inv = Path("tables/dataset_inventory.tsv")

# Resolve absolute paths
abs_config = (DATA_DIR / rel_config).resolve()
abs_cmap = (DATA_DIR / rel_cmap).resolve()
abs_inv = (DATA_DIR / rel_inv).resolve()

# Existence and non-empty checks
for p in [abs_config, abs_cmap, abs_inv]:
    assert p.exists(), f"Artifact missing: {p}"
    assert p.stat().st_size > 0, f"Artifact is empty: {p}"

print("Artifacts exist and are non-empty.")

# Validate JSON fields
with open(abs_config, "r", encoding="utf-8") as f:
    cfg = json.load(f)

required_fields = [
    "dataset_path","instructions_path","colormap_path",
    "detected_celltype_obs_key","n_cells","n_genes",
    "has_spatial_coords","gene_var_index_name",
    "matrix_format","anndata_uns_keys"
]
missing = [k for k in required_fields if k not in cfg]
assert not missing, f"Config missing fields: {missing}"
print("Config JSON has required fields.")
print({k: cfg[k] for k in ["dataset_path","detected_celltype_obs_key","n_cells","n_genes","has_spatial_coords","matrix_format"]})

# Validate colormap TSV row count matches YAML dict size
df_cmap = pd.read_csv(abs_cmap, sep="\t")
assert list(df_cmap.columns) == ["cell_type", "color"], f"Unexpected colormap columns: {list(df_cmap.columns)}"
assert len(df_cmap) == len(context["colormap_dict"]), "Colormap TSV row count mismatch YAML entries."
print("Colormap TSV validated. Rows:", len(df_cmap))

# Validate inventory TSV has required keys
df_inv = pd.read_csv(abs_inv, sep="\t")
assert list(df_inv.columns) == ["key","value"], f"Unexpected inventory columns: {list(df_inv.columns)}"
needed_keys = {"obs_columns","var_n","obs_n","spatial_keys_present","obs_celltype_key","uns_keys"}
present_keys = set(df_inv["key"].tolist())
missing_keys = needed_keys - present_keys
assert not missing_keys, f"Inventory missing keys: {missing_keys}"
print("Inventory TSV validated. Keys present:", sorted(present_keys))

print("Validation complete.")
print("Absolute artifact paths:")
print(" -", str(abs_config))
print(" -", str(abs_cmap))
print(" -", str(abs_inv))
