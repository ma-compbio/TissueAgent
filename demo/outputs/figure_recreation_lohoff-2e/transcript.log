<execute>
# Step 1: Load and inspect inputs, detect cell-type key, and collect metadata.
from pathlib import Path
import json, sys, io, os, re
import numpy as np

# Libraries likely available
import anndata as ad
import pandas as pd
import yaml

from scipy import sparse

# Workspace paths
DATA_DIR_ = DATA_DIR  # provided by REPL
dataset_rel = Path("dataset/dataset_lohoff_et_al_seqfish.h5ad")
colormap_rel = Path("uploads/colormap.yaml")
instructions_rel = Path("uploads/instructions_lohoff-2e.md")

# Resolve and validate paths are inside DATA_DIR
def resolve_and_check(rel):
    p = (DATA_DIR_ / rel)
    assert str(p.resolve()).startswith(str(DATA_DIR_.resolve())), f"Path escapes DATA_DIR: {p}"
    assert p.exists(), f"Missing required input: {p}"
    return p

dataset_p = resolve_and_check(dataset_rel)
colormap_p = resolve_and_check(colormap_rel)
instructions_p = resolve_and_check(instructions_rel)

print("Input paths:")
print(" - dataset:", str(dataset_p))
print(" - colormap:", str(colormap_p))
print(" - instructions:", str(instructions_p))

# Load AnnData
adata = ad.read_h5ad(str(dataset_p))
print(f"Loaded AnnData: n_obs={adata.n_obs}, n_vars={adata.n_vars}")

# Read instructions (only to confirm readability)
with open(instructions_p, "r", encoding="utf-8") as f:
    instr_text = f.read()
print("Instructions length (chars):", len(instr_text))

# Read colormap YAML
with open(colormap_p, "r", encoding="utf-8") as f:
    cmap_yaml = yaml.safe_load(f)
if not isinstance(cmap_yaml, dict):
    raise ValueError("Colormap YAML is not a mapping/dict.")
print("Colormap entries:", len(cmap_yaml))

# Detect matrix format
X = adata.X
if sparse.isspmatrix(X):
    matrix_format = X.getformat()
else:
    matrix_format = "dense"
print("Matrix format:", matrix_format)

# var index name
gene_var_index_name = adata.var.index.name if adata.var.index.name is not None else None
print("gene_var_index_name:", gene_var_index_name)

# Detect spatial presence and collect spatial keys present
obsm_keys = list(adata.obsm.keys()) if hasattr(adata, "obsm") else []
uns_keys = list(adata.uns.keys()) if hasattr(adata, "uns") else []
obs_cols = list(adata.obs.columns)

has_spatial_obsm = "spatial" in adata.obsm
# Heuristic pairs in obs
obs_lower = {c.lower(): c for c in obs_cols}
pair_candidates = [
    ("x", "y"),
    ("X", "Y"),
    ("imagecol", "imagerow"),
    ("imagerow", "imagecol"),
    ("pxl_col_in_fullres", "pxl_row_in_fullres"),
    ("pxl_row_in_fullres", "pxl_col_in_fullres"),
    ("x_centroid", "y_centroid"),
    ("X_centroid", "Y_centroid"),
    ("x_coord", "y_coord"),
    ("x_spatial", "y_spatial"),
    ("X_spatial", "Y_spatial"),
    ("spatial_x", "spatial_y"),
    ("spatial_y", "spatial_x"),
]
present_pairs = []
obs_cols_set = set(obs_cols)
for a, b in pair_candidates:
    if a in obs_cols_set and b in obs_cols_set:
        present_pairs.append((a, b))

has_spatial_coords = has_spatial_obsm or (len(present_pairs) > 0)

spatial_keys_present = []
if has_spatial_obsm:
    spatial_keys_present.append("obsm:spatial")
for a, b in present_pairs:
    spatial_keys_present.append(f"obs:{a},{b}")

print("Has spatial coords:", has_spatial_coords)
print("Spatial keys present:", spatial_keys_present if spatial_keys_present else ["(none)"])

# Detect cell-type column from .obs
def detect_celltype_key(obs_df):
    cols = list(obs_df.columns)
    lower_map = {c.lower(): c for c in cols}
    # Priority-ordered candidate names (lowercase)
    priors = [
        "cell_type", "celltype", "celltypes", "celltypes_merged", "cell_type_merged",
        "celltype_major", "cell_type_major", "celltype_minor", "cell_type_minor",
        "cell_ontology_class", "cell_ontology", "celllabel", "cell_label", "labels", "label",
        "annotation", "annotations", "annot", "cell_annotation", "cellclass", "cell_class",
        "ctype", "ct", "major_ct", "minor_ct",
        # Some common clustering labels (fallbacks, lowest priority)
        "cluster", "clusters", "leiden", "louvain"
    ]
    # Score function based on name match and reasonable number of categories
    n = obs_df.shape[0]
    best = None
    best_score = -1
    for i, cand in enumerate(priors):
        if cand in lower_map:
            col = lower_map[cand]
            s = obs_df[col]
            # Ensure categorical-like
            try:
                nunique = int(s.nunique(dropna=True))
            except Exception:
                continue
            # Heuristic bounds for cell types
            if nunique < 2:
                continue
            # Score: inverse unique count plus priority order
            # Prefer <= 200 categories; penalize very large unique values
            penalty = 0
            if nunique > 200:
                penalty = 2
            elif nunique > 100:
                penalty = 1
            score = (1000 - i) - penalty*100 - nunique*0.1
            if score > best_score:
                best_score = score
                best = col
    # If none found by priors, try any object/categorical columns with reasonable unique count
    if best is None:
        for col in cols:
            s = obs_df[col]
            if s.dtype.name in ("category", "object", "string"):
                try:
                    nunique = int(s.nunique(dropna=True))
                except Exception:
                    continue
                if 2 <= nunique <= 200:
                    best = col
                    break
    return best

detected_celltype_key = detect_celltype_key(adata.obs)
print("Detected cell-type obs key:", detected_celltype_key)
if detected_celltype_key is not None:
    try:
        nunique = int(adata.obs[detected_celltype_key].nunique(dropna=True))
        print(f" - unique labels: {nunique}")
        print(" - example labels:", list(adata.obs[detected_celltype_key].dropna().astype(str).unique())[:10])
    except Exception as e:
        print(" - could not summarize labels:", e)

# Save collected metadata to variables for subsequent steps
context = {
    "dataset_rel": str(dataset_rel.as_posix()),
    "instructions_rel": str(instructions_rel.as_posix()),
    "colormap_rel": str(colormap_rel.as_posix()),
    "n_cells": int(adata.n_obs),
    "n_genes": int(adata.n_vars),
    "has_spatial_coords": bool(has_spatial_coords),
    "gene_var_index_name": gene_var_index_name,
    "matrix_format": matrix_format,
    "anndata_uns_keys": list(map(str, uns_keys)),
    "obs_columns": obs_cols,
    "spatial_keys_present": spatial_keys_present,
    "detected_celltype_key": detected_celltype_key,
    "colormap_dict": cmap_yaml,
}
print("Context prepared with keys:", list(context.keys()))
