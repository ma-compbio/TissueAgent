# Axes labels and limits
ax.set_xlabel("")
ax.set_ylabel("t-statistic", fontsize=plot_style["label_fontsize"])
ax.set_ylim(plot_style["y_limits"])

# X tick labels formatting
ax.set_xticklabels(ax.get_xticklabels(), rotation=plot_style["xtick_rotation"], ha="right", fontsize=plot_style["xtick_fontsize"])
ax.tick_params(axis="y", labelsize=plot_style["ytick_fontsize"])

# Spines and ticks
for spine in ax.spines.values():
    spine.set_linewidth(plot_style["spine_linewidth"])
ax.tick_params(width=plot_style["tick_width"])

# Optional grid off
if not plot_style["grid"]:
    ax.grid(False)

plt.tight_layout()

# Save figures
fig.savefig(png_path, dpi=plot_style["dpi"], bbox_inches="tight", pad_inches=0.02)
fig.savefig(svg_path, bbox_inches="tight", pad_inches=0.02)
plt.close(fig)

print("Saved:", str(png_path.resolve()))
print("Saved:", str(svg_path.resolve()))

