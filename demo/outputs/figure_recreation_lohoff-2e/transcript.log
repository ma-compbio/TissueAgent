from PIL import Image, ImageOps
from pathlib import Path

# Step 5: Build side-by-side comparison with reference image at matched height; save PNG.

fig_dir = DATA_DIR / "figures"
cmp_path = fig_dir / "violin_vs_ref.png"

# Load generated and reference images
gen_img = Image.open(DATA_DIR / "figures" / "violin_lohoff2e.png").convert("RGBA")
ref_img = Image.open(DATA_DIR / "uploads" / "reference_lohoff-2e.png").convert("RGBA")

# Ensure matching heights by resizing generated image to reference height if needed
target_h = ref_img.height
if gen_img.height != target_h:
    new_w = int(round(gen_img.width * (target_h / gen_img.height)))
    gen_img = gen_img.resize((new_w, target_h), Image.LANCZOS)

# Minimal borders and small gutter between panels
outer_margin = 2
gutter = 8
canvas_w = outer_margin + gen_img.width + gutter + ref_img.width + outer_margin
canvas_h = max(gen_img.height, ref_img.height) + 2 * outer_margin

canvas = Image.new("RGBA", (canvas_w, canvas_h), (255, 255, 255, 255))

# Paste images
y_off = outer_margin
x_left = outer_margin
canvas.paste(gen_img, (x_left, y_off), gen_img)
x_right = outer_margin + gen_img.width + gutter
canvas.paste(ref_img, (x_right, y_off), ref_img)

# Save as PNG (convert to RGB to drop alpha)
canvas_rgb = canvas.convert("RGB")
canvas_rgb.save(cmp_path, format="PNG", optimize=True)

print("Saved:", str(cmp_path.resolve()))</execute>

