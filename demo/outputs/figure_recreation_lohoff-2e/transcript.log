# Step 2: Compute cell type order, align t-stats, resolve colors with fallback gray, record missing

# Sort cell types by mean_tstatistic descending
means_sorted = means.sort_values("mean_tstatistic", ascending=False).reset_index(drop=True)
celltype_order = means_sorted["cell_type"].tolist()
print("Sorted cell types (desc by mean_tstatistic):", celltype_order[:10] + (["..."] if len(celltype_order) > 10 else []))

# Ensure tstats only contains cell types present in means (and order)
# Keep all rows but enforce categorical order for plotting
tstats["cell_type"] = pd.Categorical(tstats["cell_type"], categories=celltype_order, ordered=True)

# Resolve colors
cmap_map = dict(zip(cmap["cell_type"], cmap["color"]))
fallback_color = "#808080"  # neutral gray
palette = {}
missing_colors = []
for ct in celltype_order:
    if ct in cmap_map and pd.notna(cmap_map[ct]) and str(cmap_map[ct]).strip() != "":
        palette[ct] = str(cmap_map[ct]).strip()
    else:
        palette[ct] = fallback_color
        missing_colors.append(ct)

print("Number of cell types:", len(celltype_order))
print("Missing color entries:", missing_colors)
print("Example palette entries:", list(palette.items())[:10])</execute>

