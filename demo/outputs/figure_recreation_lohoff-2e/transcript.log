from pathlib import Path
import json

out_config_rel = Path("configs/lohoff2e_config.json")
out_config_path = DATA_DIR / out_config_rel
out_config_path.parent.mkdir(parents=True, exist_ok=True)

config_payload = {
    "dataset_path": context["dataset_rel"],
    "instructions_path": context["instructions_rel"],
    "colormap_path": context["colormap_rel"],
    "detected_celltype_obs_key": context["detected_celltype_key"],
