# Step 4: Plot violins with seaborn using palette mapping; set labels, ticks, limits; save PNG and SVG

import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path

# Output paths
fig_dir = DATA_DIR / "figures"
fig_dir.mkdir(parents=True, exist_ok=True)
png_path = fig_dir / "violin_lohoff2e.png"
svg_path = fig_dir / "violin_lohoff2e.svg"

# Create figure and axis
plt.close("all")
fig, ax = plt.subplots(figsize=plot_style["figsize"], dpi=plot_style["dpi"])

# Seaborn style
sns.set_style("white")
sns.violinplot(
    data=tstats,
    x="cell_type",
    y="t_statistic",
    order=celltype_order,
    palette=palette,
    cut=plot_style["violin_cut"],
    inner=plot_style["inner"],
    linewidth=plot_style["violin_linewidth"],
    width=plot_style["violin_width"],
    ax=ax,
)

# Attempt to match edge color to face color for each violin body (if applicable)
# This may vary with seaborn/matplotlib versions; best-effort.
for coll in ax.collections:
    try:
        # For PolyCollection, facecolors is an array; use first as edgecolor
        fc = coll.get_facecolor()
        if fc is not None and len(fc) > 0:
            coll.set_edgecolor(fc)
    except Exception:
        pass

# Axes labels and limits
ax.set_xlabel("")
ax.set_ylabel("t-statistic", fontsize=plot_style["label_fontsize"])
ax.set_ylim(plot_style["y_limits"])

# X tick labels formatting
ax.set_xticklabels(ax.get_xticklabels(), rotation=plot_style["xtick_rotation"], ha="right", fontsize=plot_style["xtick_fontsize"])
ax.tick_params(axis="y", labelsize=plot_style["ytick_fontsize"])

# Spines and ticks
for spine in ax.spines.values():
    spine.set_linewidth(plot_style["spine_linewidth"])
ax.tick_params(width=plot_style["tick_width"])

# Optional grid off
if not plot_style["grid"]:
    ax.grid(False)

plt.tight_layout()

# Save figures
fig.savefig(png_path, dpi=plot_style["dpi"], bbox_inches="tight", pad_inches=0.02)
fig.savefig(svg_path, bbox_inches="tight", pad_inches=0.02)
plt.close(fig)

print("Saved:", str(png_path.resolve()))
print("Saved:", str(svg_path.resolve()))</execute>

