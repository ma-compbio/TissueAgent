import numpy as np

# Step 3: Compute global y-limits with margin; decide figure size and style params

# Filter to ensure we only consider rows with valid, ordered categories
valid_mask = tstats["cell_type"].notna()
tvals = tstats.loc[valid_mask, "t_statistic"].astype(float)

ymin, ymax = float(np.min(tvals)), float(np.max(tvals))
yrange = ymax - ymin if ymax > ymin else 1.0
margin = 0.07  # 7% margin
y_limits = (ymin - margin * yrange, ymax + margin * yrange)

# Figure and style parameters (aiming to match reference aspect)
# Reference is 1312x590 px (~2.22 aspect). We'll use dpi=150 to get similar physical size.
dpi = 150
fig_w_px, fig_h_px = 1312, 590
figsize = (fig_w_px / dpi, fig_h_px / dpi)

plot_style = {
    "figsize": figsize,
    "dpi": dpi,
    "violin_width": 0.9,
    "violin_linewidth": 0.8,
    "violin_cut": 0,   # don't extend beyond data
    "inner": None,     # no inner bars/points for clean look
    "xtick_rotation": 80,
    "xtick_fontsize": 8.5,
    "ytick_fontsize": 9,
    "label_fontsize": 10.5,
    "title_fontsize": 11,
    "spine_linewidth": 0.8,
    "tick_width": 0.8,
    "y_limits": y_limits,
    "grid": False,
}

print("Computed y_limits:", y_limits)
print("Figure size (in):", figsize, "DPI:", dpi)
print("Style params preview:", {k: plot_style[k] for k in ["violin_width","violin_linewidth","xtick_rotation","label_fontsize"]})</execute>

