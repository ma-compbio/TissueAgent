import anndata as ad
import pandas as pd
from pathlib import Path

ds_path = DATA_DIR / "dataset" / "dataset_lohoff_et_al_seqfish.h5ad"
assert ds_path.exists(), f"Dataset not found: {ds_path}"
adata = ad.read_h5ad(str(ds_path))
print("AnnData loaded:", adata.shape)

# Validate cell-type column
ct_key = "celltype_mapped_refined"
assert ct_key in adata.obs.columns, f"Cell-type column '{ct_key}' not found in .obs. Available: {list(adata.obs.columns)[:30]}"
print("Cell-type key present:", ct_key)

# Determine cell-type order (preserve dataset's order)
if pd.api.types.is_categorical_dtype(adata.obs[ct_key]):
    cell_types_order = list(adata.obs[ct_key].cat.categories)
else:
    # first-seen order
    cell_types_order = list(pd.unique(adata.obs[ct_key].astype(str)))
print("Cell types (first 30):", cell_types_order[:30] + (["..."] if len(cell_types_order) > 30 else []))
print("N cell types:", len(cell_types_order))

# Inspect spatial and graph structures
print("obsm keys:", list(adata.obsm.keys()))
print("obsp keys:", list(adata.obsp.keys()))
print("uns keys (first 30):", list(adata.uns.keys())[:30])

# Peek at likely embryo/z keys from obs
obs_cols = list(adata.obs.columns)
candidates_embryo = [c for c in obs_cols if any(k in c.lower() for k in ["embryo", "emb", "sample", "batch"])]
candidates_z = [c for c in obs_cols if re.fullmatch(r"z|z_?slice|slice|zs|zplane|z_plane", c, flags=re.IGNORECASE) or "z" in c.lower() and "size" not in c.lower()]
print("Candidate embryo columns:", candidates_embryo[:10])
print("Candidate z-slice columns:", candidates_z[:10])

# Show small head of those candidates
head_preview_cols = [c for c in (candidates_embryo + candidates_z) if c in adata.obs.columns][:6]
print("Preview of embryo/z columns:")
print(adata.obs[head_preview_cols].head(3) if head_preview_cols else "No embryo/z preview columns found")
