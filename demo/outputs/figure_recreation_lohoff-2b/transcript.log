import json
import numpy as np
import pandas as pd
from pathlib import Path

# Step 4: Decide plotting aesthetics and write artifacts

# Decide if coordinates look like pixel units vs normalized/embedding
x_span = x_max - x_min
y_span = y_max - y_min
looks_like_pixels = (x_max > 50 or y_max > 50 or x_span > 50 or y_span > 50)

# Heuristic point size and alpha
if looks_like_pixels:
    point_size = 6.0  # within 3–8 as per guidance
    alpha = 0.9
    figsize = [6.0, 6.0]
else:
    # Embedding/normalized scale; keep points modest to avoid overplotting at ~19k cells
    point_size = 5.0
    alpha = 0.9
    figsize = [6.0, 6.0]

dpi = 300
invert_y = True
background = "white"
axis_off = True

# Prepare directories
tables_dir = (DATA_DIR / "tables")
configs_dir = (DATA_DIR / "configs")
tables_dir.mkdir(parents=True, exist_ok=True)
configs_dir.mkdir(parents=True, exist_ok=True)

# Inventory table
inv_rows = [{
    "dataset_path": str(Path("dataset") / "dataset_lohoff_et_al_seqfish.h5ad"),
    "n_obs": int(adata.n_obs),
    "n_vars": int(adata.n_vars),
    "coord_x_key": x_key,
    "coord_y_key": y_key,
    "coord_source": "obsm:spatial" if coord_source == "obsm" and x_key.startswith("spatial") else coord_source,
    "coord_x_min": float(x_min),
    "coord_x_max": float(x_max),
    "coord_y_min": float(y_min),
    "coord_y_max": float(y_max),
    "cell_type_key": selected_celltype_key,
    "n_cell_types": int(n_cell_types),
}]
inv_df = pd.DataFrame(inv_rows, columns=[
    "dataset_path","n_obs","n_vars","coord_x_key","coord_y_key","coord_source",
    "coord_x_min","coord_x_max","coord_y_min","coord_y_max","cell_type_key","n_cell_types"
])
inv_path = tables_dir / "data_inventory.tsv"
inv_df.to_csv(inv_path, sep="\t", index=False)

# Colormap resolved table (already built as colormap_resolved_df)
cmap_path = tables_dir / "colormap_resolved.tsv"
colormap_resolved_df.to_csv(cmap_path, sep="\t", index=False)

# Plot config JSON
plot_config = {
    "dataset_path": str(Path("dataset") / "dataset_lohoff_et_al_seqfish.h5ad"),
    "coord_source": "obsm:spatial" if coord_source == "obsm" and x_key.startswith("spatial") else coord_source,
    "x_key": x_key,
    "y_key": y_key,
    "cell_type_key": selected_celltype_key,
    "color_map": resolved_color_map,  # label -> hex
    "point_size": point_size,
    "alpha": alpha,
    "invert_y": True,
    "figsize": figsize,
    "dpi": dpi,
    "background": background,
    "axis_off": axis_off,
}
config_path = configs_dir / "plot_config.json"
with open(config_path, "w") as f:
    json.dump(plot_config, f, indent=2)

# Print previews and saved paths
print("Saved inventory to:", inv_path)
print(inv_df)

print("Saved colormap to:", cmap_path)
print(colormap_resolved_df.head(10))

print("Saved config to:", config_path)
print(json.dumps(plot_config, indent=2)[:800] + ("..." if len(json.dumps(plot_config, indent=2))>800 else ""))</execute>

