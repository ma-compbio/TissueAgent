# Step 3) Render base spatial scatter; save PNG and SVG; validate existence.

import matplotlib
import matplotlib.pyplot as plt
import numpy as np

config = _state["config"]
df_sorted = _state["df_sorted"]
extents = _state["extents"]

# Visual parameters from config (source of truth)
point_size = float(config.get("point_size", 1.0))
alpha = float(config.get("alpha", 1.0))
invert_y = bool(config.get("invert_y", True))
figsize = tuple(config.get("figsize", [6, 6]))
dpi = int(config.get("dpi", 200))
axis_off = bool(config.get("axis_off", True))
background = config.get("background", "#ffffff") or "#ffffff"

# Create figure
fig, ax = plt.subplots(figsize=figsize, dpi=dpi)
fig.patch.set_facecolor(background)
ax.set_facecolor(background)

# Equal aspect
ax.set_aspect("equal", adjustable="box")

# Scatter plot with deterministic order
ax.scatter(
    df_sorted["x"].to_numpy(),
    df_sorted["y"].to_numpy(),
    c=df_sorted["_color"].to_numpy(),
    s=point_size,
    alpha=alpha,
    linewidths=0,
    edgecolors="none",
    rasterized=False,
)

# Styling
if invert_y:
    ax.invert_yaxis()
if axis_off:
    ax.axis("off")

# Tight layout
plt.tight_layout(pad=0)

# Output paths
fig_dir = _state["fig_dir"]
png_path = fig_dir / "spatial_scatter.png"
svg_path = fig_dir / "spatial_scatter.svg"

# Save
fig.savefig(png_path, bbox_inches="tight", facecolor=background)
fig.savefig(svg_path, bbox_inches="tight", facecolor=background)
plt.close(fig)

# Validate
assert png_path.exists(), "PNG was not saved"
assert svg_path.exists(), "SVG was not saved"

_state.update({
    "spatial_scatter_png": png_path,
    "spatial_scatter_svg": svg_path,
})
print("Saved base scatter:", str(png_path), str(svg_path))
