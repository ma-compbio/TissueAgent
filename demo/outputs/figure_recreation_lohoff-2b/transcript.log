import numpy as np
import pandas as pd

# Step 2: Detect spatial coordinates and compute ranges
coord_source = None
x_key = None
y_key = None
x_vals = None
y_vals = None

# Helper to standardize obsm array selection
def pick_from_obsm(adata, keys=('spatial','X_spatial','X_spatial_umap','spatial_coords')):
    for k in keys:
        if k in adata.obsm:
            arr = adata.obsm[k]
            if hasattr(arr, "shape") and arr.shape[1] >= 2:
                return ("obsm", k, arr[:,0].astype(float), arr[:,1].astype(float))
    return None

picked = pick_from_obsm(adata)
if picked is not None:
    coord_source, obsm_key, x_vals, y_vals = picked
    x_key = f"{obsm_key}:0"
    y_key = f"{obsm_key}:1"
else:
    # Fallback to obs columns
    obs = adata.obs
    candidates = [
        ("x", "y"),
        ("X", "Y"),
        ("X_centroid", "Y_centroid"),
        ("X_centroids", "Y_centroids"),
        ("x_centroid", "y_centroid"),
        ("x_coord","y_coord"),
        ("x_coordinate","y_coordinate"),
        ("pos_x","pos_y"),
        ("pxl_col_in_fullres","pxl_row_in_fullres"),
    ]
    found = None
    lower_cols = {c.lower(): c for c in obs.columns}
    for a,b in candidates:
        if a in obs.columns and b in obs.columns:
            found = (a,b)
            break
        if a.lower() in lower_cols and b.lower() in lower_cols:
            found = (lower_cols[a.lower()], lower_cols[b.lower()])
            break
    if found:
        ax, ay = found
        coord_source = "obs"
        x_key, y_key = ax, ay
        x_vals = pd.to_numeric(obs[ax], errors="coerce").values
        y_vals = pd.to_numeric(obs[ay], errors="coerce").values

# Validate we found coordinates
if x_vals is None or y_vals is None:
    raise RuntimeError("Could not detect spatial coordinate fields in .obsm or .obs")

# Compute ranges (ignoring NaNs)
x_min = float(np.nanmin(x_vals))
x_max = float(np.nanmax(x_vals))
y_min = float(np.nanmin(y_vals))
y_max = float(np.nanmax(y_vals))

print("Coordinate source:", coord_source)
print("X key:", x_key, "Y key:", y_key)
print("X range:", (x_min, x_max))
print("Y range:", (y_min, y_max))

# Detect cell-type column
obs = adata.obs
cand_list = ['cell_type', 'celltype', 'cell_type_leiden', 'CellType', 'cell_type_major', 'cell_type_discrete']
# Add heuristic matches
all_cols = list(obs.columns)
def is_label_like(series):
    return (pd.api.types.is_categorical_dtype(series) or pd.api.types.is_object_dtype(series)) and series.astype("string").str.len().notna().sum() > 0

# First try provided candidates (case-insensitive)
selected_celltype_key = None
for c in cand_list:
    for col in all_cols:
        if col.lower() == c.lower():
            if is_label_like(obs[col]):
                selected_celltype_key = col
                break
    if selected_celltype_key:
        break

# Heuristic: columns containing "celltype" or "cell_type" or "annotation" or "label" or "cluster"
if selected_celltype_key is None:
    heur_cols = [c for c in all_cols if any(tok in c.lower() for tok in ["celltype","cell_type","annotation","label","cluster","cell_type","cell.type"])]
    heur_cols = [c for c in heur_cols if is_label_like(obs[c])]
    if heur_cols:
        # Choose most granular (highest n_unique)
        uniq_counts = {c: obs[c].astype("string").nunique(dropna=True) for c in heur_cols}
        selected_celltype_key = max(uniq_counts, key=uniq_counts.get)

# Final fallback: any categorical/object column with reasonable cardinality
if selected_celltype_key is None:
    cand_any = [c for c in all_cols if is_label_like(obs[c])]
    if cand_any:
        uniq_counts = {c: obs[c].astype("string").nunique(dropna=True) for c in cand_any}
        selected_celltype_key = max(uniq_counts, key=uniq_counts.get)

if selected_celltype_key is None:
    raise RuntimeError("Could not detect a cell-type annotation column.")

# Normalize to string and category for counting
celltypes_series = obs[selected_celltype_key].astype("string")
unique_celltypes = sorted([ct for ct in celltypes_series.dropna().unique().tolist()])
n_cell_types = len(unique_celltypes)
counts = celltypes_series.value_counts(dropna=True).to_dict()

print("Selected cell type column:", selected_celltype_key)
print("Number of unique cell types:", n_cell_types)
print("First 20 cell types:", unique_celltypes[:20] + (["..."] if n_cell_types > 20 else []))</execute>

