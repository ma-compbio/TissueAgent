# Step 4) Try overlay on reference image; if mismatch, create two-panel; save PNG.

import numpy as np
import matplotlib.pyplot as plt
import matplotlib.image as mpimg

config = _state["config"]
df_sorted = _state["df_sorted"]
extents = _state["extents"]
ref_img_path = _state["ref_img_path"]
ref_img_exists = _state["ref_img_exists"]

# Visual parameters from config
point_size = float(config.get("point_size", 1.0))
alpha = float(config.get("alpha", 1.0))
invert_y = bool(config.get("invert_y", True))
figsize = tuple(config.get("figsize", [6, 6]))
dpi = int(config.get("dpi", 200))
axis_off = bool(config.get("axis_off", True))
background = config.get("background", "#ffffff") or "#ffffff"

# Helper: check aspect compatibility between data extent and image
def aspect_ratio_compatible(extents, img):
    x_min, x_max, y_min, y_max = extents
    data_ar = (x_max - x_min) / max(1e-9, (y_max - y_min))
    h, w = img.shape[0], img.shape[1]
    img_ar = w / max(1e-9, h)
    rel_diff = abs(data_ar - img_ar) / max(img_ar, 1e-9)
    return data_ar, img_ar, rel_diff

overlay_used = False
spatial_on_ref_path = _state["fig_dir"] / "spatial_on_reference.png"

if ref_img_exists:
    img = mpimg.imread(ref_img_path)
    data_ar, img_ar, rel_diff = aspect_ratio_compatible(extents, img)
    # Threshold for acceptable mismatch
    compatible = rel_diff < 0.1

    if compatible:
        # Overlay mode
        fig, ax = plt.subplots(figsize=figsize, dpi=dpi)
        fig.patch.set_facecolor(background)
        ax.set_facecolor(background)
        ax.set_aspect("equal", adjustable="box")

        # Draw background image with data extents
        ax.imshow(img, extent=extents, origin="upper", zorder=0)

        # Draw scatter above
        ax.scatter(
            df_sorted["x"].to_numpy(),
            df_sorted["y"].to_numpy(),
            c=df_sorted["_color"].to_numpy(),
            s=point_size,
            alpha=alpha,
            linewidths=0,
            edgecolors="none",
            zorder=1,
            rasterized=False,
        )

        if invert_y:
            ax.invert_yaxis()
        if axis_off:
            ax.axis("off")

        plt.tight_layout(pad=0)
        fig.savefig(spatial_on_ref_path, bbox_inches="tight", facecolor=background)
        plt.close(fig)
        overlay_used = True
    else:
        # Two-panel figure: left image, right scatter
        fig, axes = plt.subplots(1, 2, figsize=(figsize[0]*2, figsize[1]), dpi=dpi, gridspec_kw={"wspace":0.02})
        for ax in axes:
            ax.set_facecolor(background)
        fig.patch.set_facecolor(background)

        # Left: reference image
        axes[0].imshow(img, origin="upper")
        if axis_off:
            axes[0].axis("off")

        # Right: scatter
        ax = axes[1]
        ax.set_aspect("equal", adjustable="box")
        ax.scatter(
            df_sorted["x"].to_numpy(),
            df_sorted["y"].to_numpy(),
            c=df_sorted["_color"].to_numpy(),
            s=point_size,
            alpha=alpha,
            linewidths=0,
            edgecolors="none",
            zorder=1,
            rasterized=False,
        )
        if invert_y:
            ax.invert_yaxis()
        if axis_off:
            ax.axis("off")
        plt.tight_layout(pad=0)
        fig.savefig(spatial_on_ref_path, bbox_inches="tight", facecolor=background)
        plt.close(fig)
        overlay_used = False
else:
    # No reference image: fall back to saving scatter only as the "on_reference" artifact
    import shutil
    shutil.copyfile(_state["spatial_scatter_png"], spatial_on_ref_path)
