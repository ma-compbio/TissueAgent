from pathlib import Path
import json, datetime, sys

# Ensure DATA_DIR is available
try:
    DATA_DIR
except NameError as e:
    raise RuntimeError("DATA_DIR is not defined in the REPL environment") from e

# 1) Load and validate config, YAML, dataset path; create figures/ and logs/ dirs.

# Paths
config_path = DATA_DIR / "configs" / "plot_config.json"
yaml_path = DATA_DIR / "uploads" / "colormap.yaml"
ref_img_path = DATA_DIR / "uploads" / "reference_lohoff-2b.png"
fig_dir = DATA_DIR / "figures"
logs_dir = DATA_DIR / "logs"

# Create output dirs
fig_dir.mkdir(parents=True, exist_ok=True)
logs_dir.mkdir(parents=True, exist_ok=True)

# Load config JSON
assert config_path.exists(), f"Config file not found: {config_path}"
with open(config_path, "r") as f:
    config = json.load(f)

# Validate minimal required keys exist in config
required_keys = ["dataset_path", "x_key", "y_key", "cell_type_key", "color_map", "point_size", "alpha", "invert_y", "figsize", "dpi", "axis_off", "background"]
missing = [k for k in required_keys if k not in config]
assert not missing, f"Missing required config keys: {missing}"

# Resolve dataset path from config, ensuring it's inside DATA_DIR
raw_ds_path = Path(config["dataset_path"])
ds_path = (DATA_DIR / raw_ds_path) if not raw_ds_path.is_absolute() else raw_ds_path
# Security: must be within DATA_DIR
assert str(ds_path.resolve()).startswith(str(DATA_DIR.resolve())), f"Dataset path {ds_path} is outside DATA_DIR"
assert ds_path.exists(), f"Dataset file does not exist: {ds_path}"

# Load YAML mapping (optional, for reference)
colormap_yaml = None
yaml_loaded = False
yaml_error = None
if yaml_path.exists():
    try:
        import yaml  # PyYAML
        with open(yaml_path, "r") as yf:
            colormap_yaml = yaml.safe_load(yf)
        yaml_loaded = True
    except Exception as e:
        yaml_error = repr(e)

# Check reference image presence (will be handled during plotting)
ref_img_exists = ref_img_path.exists()

# Persist state for next steps
_state = {
    "config": config,
    "ds_path": ds_path,
    "fig_dir": fig_dir,
    "logs_dir": logs_dir,
    "yaml_loaded": yaml_loaded,
    "colormap_yaml": colormap_yaml,
    "yaml_error": yaml_error,
    "ref_img_path": ref_img_path,
    "ref_img_exists": ref_img_exists,
}
# Print minimal confirmation
print("Config loaded. Dataset path:", str(ds_path))
print("Figures dir:", str(fig_dir), "Logs dir:", str(logs_dir))
print("YAML loaded:", yaml_loaded, "Ref image exists:", ref_img_exists)
