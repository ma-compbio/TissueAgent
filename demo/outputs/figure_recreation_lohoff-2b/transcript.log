import yaml
import matplotlib.colors as mcolors
import pandas as pd

# Step 3: Parse YAML colormap; normalize keys and resolve mapping for observed cell types

yaml_fallback_color = "#bdbdbd"

def normalize_label_key(s: str) -> str:
    # Trim whitespace and lowercase for case-insensitive matching
    return (s or "").strip().lower()

def normalize_color_to_hex(cstr: str, fallback="#bdbdbd") -> str:
    try:
        # matplotlib accepts many formats; ensure 6-digit hex without alpha
        return mcolors.to_hex(mcolors.to_rgba(cstr), keep_alpha=False)
    except Exception:
        return fallback

# Load YAML
with open(yaml_path, "r") as f:
    yobj = yaml.safe_load(f)

if not isinstance(yobj, dict):
    raise RuntimeError("YAML colormap must be a mapping from cell type -> color.")

# Build normalized YAML mapping
yaml_map_norm = {}
for k, v in yobj.items():
    if not isinstance(k, str):
        continue
    if not isinstance(v, str):
        # Attempt to stringify colors if e.g., lists
        try:
            v = str(v)
        except Exception:
            continue
    nk = normalize_label_key(k)
    yaml_map_norm[nk] = normalize_color_to_hex(v, fallback=yaml_fallback_color)

# Resolve mapping for observed cell types
observed_labels = unique_celltypes  # from previous step
resolved_rows = []
resolved_color_map = {}

for label in observed_labels:
    nlabel = normalize_label_key(label)
    if nlabel in yaml_map_norm:
        color_hex = yaml_map_norm[nlabel]
        source = "yaml"
    else:
        color_hex = yaml_fallback_color
        source = "fallback"
    resolved_color_map[label] = color_hex
    resolved_rows.append({
        "cell_type": label,
        "color_hex": color_hex,
        "present_in_data": True,
        "used_color": source,
        "count": int(counts.get(label, 0)),
    })

colormap_resolved_df = pd.DataFrame(resolved_rows).sort_values("cell_type").reset_index(drop=True)

print("Resolved color map entries:", len(resolved_color_map))
print("First 10 resolved rows:")
print(colormap_resolved_df.head(10))</execute>

