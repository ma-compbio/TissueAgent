# Step 2) Read AnnData; resolve coordinates; extract x, y, cell_type; build color mapping; compute extents and deterministic order.

import anndata as ad
import numpy as np
import pandas as pd

config = _state["config"]
ds_path = _state["ds_path"]

# Load dataset
adata = ad.read_h5ad(str(ds_path))
n_obs = adata.n_obs

# Resolve keys from config
x_key = config["x_key"]
y_key = config["y_key"]
ct_key = config["cell_type_key"]

# Helper to extract coordinates from obs or obsm based on key string
def extract_coords(adata, x_key, y_key):
    # 1) Directly from .obs columns
    if x_key in adata.obs.columns and y_key in adata.obs.columns:
        x = adata.obs[x_key].to_numpy()
        y = adata.obs[y_key].to_numpy()
        source = {"type": "obs", "x_key": x_key, "y_key": y_key}
        return x, y, source
    # 2) Pattern: "obsm:<key>[:<idx>]" or "[<idx>]"
    def parse_obsm_key(k):
        if isinstance(k, str) and k.startswith("obsm:"):
            rest = k.split("obsm:", 1)[1]
            # allow formats like "spatial:0" or "spatial[0]"
            if ":" in rest:
                obsm_key, col = rest.split(":", 1)
            elif "[" in rest and rest.endswith("]"):
                obsm_key = rest[:rest.index("[")]
                col = rest[rest.index("[")+1:-1]
            else:
                obsm_key, col = rest, None
            try:
                col = int(col) if col is not None else None
            except Exception:
                col = None
            return obsm_key, col
        return None, None

    x_ok, x_col = parse_obsm_key(x_key)
    y_ok, y_col = parse_obsm_key(y_key)
    # If both specify same obsm key with explicit column indices
    if x_ok and y_ok and x_ok == y_ok and x_ok in adata.obsm_keys():
        arr = adata.obsm[x_ok]
        if arr.ndim == 2:
            xi = 0 if x_col is None else x_col
            yi = 1 if y_col is None else y_col
            x = np.asarray(arr[:, xi]).reshape(-1)
            y = np.asarray(arr[:, yi]).reshape(-1)
            source = {"type": "obsm", "key": x_ok, "x_col": xi, "y_col": yi}
            return x, y, source

    # 3) Common fallback: use .obsm['spatial'] if present
    if "spatial" in adata.obsm_keys():
        arr = adata.obsm["spatial"]
        if arr.ndim == 2 and arr.shape[1] >= 2:
            x = np.asarray(arr[:, 0]).reshape(-1)
            y = np.asarray(arr[:, 1]).reshape(-1)
            source = {"type": "obsm", "key": "spatial", "x_col": 0, "y_col": 1, "fallback": True}
            return x, y, source

    # 4) No match found
    raise KeyError(f"Could not resolve coordinates from config keys: x_key={x_key}, y_key={y_key}")

# Extract coordinates
x, y, coord_source = extract_coords(adata, x_key, y_key)

# Extract cell type labels
if ct_key not in adata.obs.columns:
    raise KeyError(f"Cell type key '{ct_key}' not found in adata.obs. Available columns: {list(adata.obs.columns)[:20]}...")
cell_types = adata.obs[ct_key].astype("string").fillna("NA").to_numpy()

# Aggregate into DataFrame for easy handling
df = pd.DataFrame({
    "x": pd.Series(x, dtype="float64"),
    "y": pd.Series(y, dtype="float64"),
    "cell_type": pd.Series(cell_types, dtype="string")
})

# Drop rows with missing coordinates
before = len(df)
df = df.dropna(subset=["x", "y"])
dropped = before - len(df)

# Build color mapping from config with fallback
cfg_map = config.get("color_map", {}) or {}
# Normalize mapping keys/values to strings
color_map = {str(k): str(v) for k, v in cfg_map.items()}
fallback_color = "#bdbdbd"
unique_labels = sorted(pd.unique(df["cell_type"].astype(str)))
missing_labels = [lbl for lbl in unique_labels if lbl not in color_map]
used_fallback = len(missing_labels) > 0

# Resolve colors per row
def map_color(lbl):
    return color_map.get(lbl, fallback_color)

colors = df["cell_type"].astype(str).map(map_color).to_numpy()

# Deterministic plotting order: sort by cell_type, then y, then x
df["_color"] = colors
df_sorted = df.sort_values(by=["cell_type", "y", "x"], kind="mergesort").reset_index(drop=True)

# Extents
x_min, x_max = float(np.nanmin(df_sorted["x"])), float(np.nanmax(df_sorted["x"]))
y_min, y_max = float(np.nanmin(df_sorted["y"])), float(np.nanmax(df_sorted["y"]))
extents = [x_min, x_max, y_min, y_max]

# Counts per label (based on filtered df)
label_counts = df_sorted["cell_type"].value_counts().sort_index().to_dict()

# Persist state for plotting and logging
_state.update({
    "adata_n_obs": n_obs,
    "coord_source": coord_source,
    "df_sorted": df_sorted,
    "extents": extents,
    "label_counts": label_counts,
    "unique_labels": unique_labels,
    "missing_labels": missing_labels,
    "used_fallback": used_fallback,
})
print(f"AnnData loaded: n_obs={n_obs}, after_drop={len(df_sorted)}, dropped_na={dropped}")
print("Coord source:", coord_source)
print("Unique labels (up to 20):", unique_labels[:20] + (["..."] if len(unique_labels) > 20 else []))
print("Missing labels in color_map:", missing_labels[:10] + (["..."] if len(missing_labels) > 10 else []))
</execute>

